import { LineEdit, ListView, Button, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { EntryItem, AppState } from "../globals.slint";

// Ліва панель: пошук + список записів. Читає й пише AppState напряму.
export component EntryList inherits Rectangle {
    background: #0f3460;
    min-width: 260px;

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // ── Topbar ──────────────────────────────────────────────────────────
        Rectangle {
            height: 56px;
            background: #0a2540;

            HorizontalBox {
                padding: 0px;
                spacing: 0px;

                Rectangle { width: 16px; }           // left inset

                HorizontalBox {
                    padding: 0px;
                    spacing: 8px;
                    horizontal-stretch: 1;

                    Text {
                        text: "pass-vault";
                        font-size: 15px;
                        font-weight: 700;
                        color: #e0e0e0;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Button {
                        text: "+";
                        clicked => {
                            AppState.new-entry-requested();
                            AppState.reset-idle-timer();
                        }
                    }
                    Button {
                        text: "🔒";
                        clicked => { AppState.logout(); }
                    }
                }

                Rectangle { width: 12px; }           // right inset
            }
        }

        // ── Пошук ───────────────────────────────────────────────────────────
        Rectangle {
            height: 48px;
            background: #0d2d50;

            VerticalBox {
                padding: 8px;

                LineEdit {
                    placeholder-text: "Пошук...";
                    edited(text) => {
                        AppState.search-query = text;
                        AppState.search-changed(text);
                        AppState.reset-idle-timer();
                    }
                }
            }
        }

        // ── Лічильник ───────────────────────────────────────────────────────
        Rectangle {
            height: 28px;
            background: #0d2d50;

            HorizontalBox {
                padding: 0px;
                spacing: 0px;

                Rectangle { width: 16px; }           // left inset

                Text {
                    text: AppState.entries.length + " записів";
                    font-size: 11px;
                    color: #6688aa;
                    vertical-alignment: center;
                }
            }
        }

        // ── Список ──────────────────────────────────────────────────────────
        ListView {
            vertical-stretch: 1;

            for entry in AppState.entries: Rectangle {
                height: 64px;
                background: entry.id == AppState.selected-entry-id
                    ? #1a4a7a
                    : (touch.has-hover ? #143d68 : transparent);

                animate background { duration: 100ms; }

                touch := TouchArea {
                    clicked => {
                        AppState.select-entry(entry.id);
                        AppState.reset-idle-timer();
                    }
                }

                HorizontalBox {
                    padding: 12px;
                    spacing: 10px;

                    // Аватар
                    Rectangle {
                        width: 40px;
                        height: 40px;
                        border-radius: 20px;
                        background: #1e5f9e;

                        Text {
                            text: "●";
                            font-size: 16px;
                            font-weight: 700;
                            color: #e0e0e0;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // Назва + username
                    VerticalBox {
                        padding: 0px;
                        spacing: 2px;
                        alignment: center;
                        horizontal-stretch: 1;

                        Text {
                            text: entry.title;
                            font-size: 14px;
                            font-weight: 600;
                            color: #e0e0e0;
                            overflow: elide;
                        }
                        Text {
                            text: entry.username;
                            font-size: 12px;
                            color: #8899bb;
                            overflow: elide;
                        }
                    }

                    // Зірочка (обране)
                    if entry.favorite: Text {
                        text: "★";
                        font-size: 14px;
                        color: #f0c040;
                        vertical-alignment: center;
                    }
                }

                // Розділювач
                Rectangle {
                    y: parent.height - 1px;
                    height: 1px;
                    background: #1a3a5a;
                }
            }
        }

        // ── Спінер ──────────────────────────────────────────────────────────
        if AppState.is-loading: Rectangle {
            height: 40px;
            background: #0d2d50;

            VerticalBox {
                padding: 0px;

                Text {
                    text: "Завантаження...";
                    font-size: 12px;
                    color: #6688aa;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
