import { Button, LineEdit, TextEdit, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { EntryItem, AppState } from "../globals.slint";

// ── Допоміжні компоненти (визначаються до EntryDetail) ─────────────────────

component ViewField inherits Rectangle {
    in property <string> label;
    in property <string> value;

    border-radius: 8px;
    background: #1a2540;

    VerticalBox {
        padding: 12px;
        spacing: 4px;

        Text {
            text: root.label;
            font-size: 11px;
            color: #5566aa;
            font-weight: 600;
        }
        Text {
            text: root.value == "" ? "—" : root.value;
            font-size: 14px;
            color: root.value == "" ? #445566 : #c0d0e0;
            overflow: elide;
        }
    }
}

component EditField inherits VerticalBox {
    in property <string> label;
    in-out property <string> value;

    spacing: 6px;

    Text {
        text: root.label;
        font-size: 11px;
        color: #5566aa;
        font-weight: 600;
    }
    LineEdit {
        text <=> root.value;
        placeholder-text: root.label;
    }
}

// ── Права панель ───────────────────────────────────────────────────────────

export component EntryDetail inherits Rectangle {
    // UI-only: передається з AppWindow (show-password живе на root).
    in-out property <bool> show-password: false;
    // Заповнюється AppWindow коли пароль прийнятий з GenerateDialog.
    in property <string> accepted-password: "";

    // Події, які потребують координації на рівні AppWindow.
    callback delete-requested(int);
    callback generate-password-requested();

    // Локальний стан форми.
    private property <string> edit-title: "";
    private property <string> edit-username: "";
    private property <string> edit-url: "";
    private property <string> edit-password: "";
    private property <string> edit-notes: "";
    private property <bool> notes-expanded: false;

    // Дзеркала глобалів — лише для `changed`-хуків (Slint не дозволяє
    // `changed AppState.x` напряму).
    property <EntryItem> _entry-mirror: AppState.selected-entry;
    property <string> _mode-mirror: AppState.detail-mode;

    changed _entry-mirror => {
        edit-title = root._entry-mirror.title;
        edit-username = root._entry-mirror.username;
        edit-url = root._entry-mirror.url;
        edit-password = "";
        edit-notes = root._entry-mirror.notes;
        root.notes-expanded = false;
    }

    changed _mode-mirror => {
        if (root._mode-mirror == "new") {
            edit-title = "";
            edit-username = "";
            edit-url = "";
            edit-password = "";
            edit-notes = "";
        }
    }

    changed accepted-password => {
        if (root.accepted-password != "") {
            edit-password = root.accepted-password;
        }
    }

    background: #12192b;

    // ── Порожній стан ───────────────────────────────────────────────────────
    if AppState.detail-mode == "view" && AppState.selected-entry.id <= 0: VerticalLayout {
        alignment: center;
        spacing: 12px;

        Text {
            text: "🔑";
            font-size: 48px;
            horizontal-alignment: center;
        }
        Text {
            text: "Оберіть запис або створіть новий";
            font-size: 14px;
            color: #5566aa;
            horizontal-alignment: center;
        }
    }

    // ── Режим перегляду ─────────────────────────────────────────────────────
    if AppState.detail-mode == "view" && AppState.selected-entry.id > 0: VerticalLayout {
        padding: 32px;
        spacing: 16px;

        HorizontalBox {
            spacing: 8px;

            Text {
                text: AppState.selected-entry.title;
                font-size: 22px;
                font-weight: 700;
                color: #e0e0e0;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }

            Button {
                text: "Редагувати";
                clicked => {
                    AppState.detail-mode = "edit";
                    AppState.reset-idle-timer();
                }
            }
            Button {
                text: "Видалити";
                clicked => { root.delete-requested(AppState.selected-entry.id); }
            }
        }

        ViewField { label: "Логін"; value: AppState.selected-entry.username; }
        ViewField { label: "URL"; value: AppState.selected-entry.url; }
        ViewField { label: "Категорія"; value: AppState.selected-entry.category; }
        Rectangle {
            border-radius: 8px;
            background: #1a2540;

            VerticalBox {
                padding: 12px;
                spacing: 4px;

                HorizontalBox {
                    spacing: 4px;

                    Text {
                        text: "Нотатки";
                        font-size: 11px;
                        color: #5566aa;
                        font-weight: 600;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    if AppState.selected-entry.notes != "": Button {
                        text: root.notes-expanded ? "▲" : "▼";
                        clicked => { root.notes-expanded = !root.notes-expanded; }
                    }
                }

                Text {
                    text: AppState.selected-entry.notes == "" ? "—" : AppState.selected-entry.notes;
                    font-size: 14px;
                    color: AppState.selected-entry.notes == "" ? #445566 : #c0d0e0;
                    wrap: root.notes-expanded ? word-wrap : no-wrap;
                    overflow: root.notes-expanded ? clip : elide;
                }
            }
        }
        ViewField { label: "Оновлено"; value: AppState.selected-entry.updated-at; }

        Rectangle {
            border-radius: 8px;
            background: #1a2540;

            VerticalBox {
                padding: 12px;
                spacing: 6px;

                Text {
                    text: "Пароль";
                    font-size: 11px;
                    color: #5566aa;
                    font-weight: 600;
                }

                HorizontalBox {
                    spacing: 8px;

                    Text {
                        text: root.show-password
                            ? AppState.selected-entry.password
                            : "••••••••••••";
                        font-size: 14px;
                        color: root.show-password ? #e0e0e0 : #5566aa;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }

                    Button {
                        text: root.show-password ? "Сховати" : "Показати";
                        clicked => {
                            root.show-password = !root.show-password;
                            AppState.reveal-password(AppState.selected-entry.id);
                            AppState.reset-idle-timer();
                        }
                    }
                    Button {
                        text: "Копіювати";
                        clicked => {
                            AppState.copy-password(AppState.selected-entry.id);
                            AppState.reset-idle-timer();
                        }
                    }
                }
            }
        }
    }

    // ── Режим редагування / новий ───────────────────────────────────────────
    if AppState.detail-mode == "edit" || AppState.detail-mode == "new": VerticalLayout {
        padding: 32px;
        spacing: 16px;

        Text {
            text: AppState.detail-mode == "new" ? "Новий запис" : "Редагування";
            font-size: 20px;
            font-weight: 700;
            color: #e0e0e0;
        }

        EditField { label: "Назва *"; value <=> root.edit-title; }
        EditField { label: "Логін"; value <=> root.edit-username; }
        EditField { label: "URL"; value <=> root.edit-url; }

        VerticalBox {
            spacing: 6px;

            Text {
                text: "Нотатки";
                font-size: 11px;
                color: #5566aa;
                font-weight: 600;
            }
            TextEdit {
                text <=> root.edit-notes;
                placeholder-text: "Нотатки";
                min-height: 80px;
            }
        }

        VerticalBox {
            spacing: 6px;

            Text {
                text: "Пароль";
                font-size: 11px;
                color: #5566aa;
                font-weight: 600;
            }

            HorizontalBox {
                spacing: 8px;

                LineEdit {
                    horizontal-stretch: 1;
                    input-type: password;
                    placeholder-text: "Пароль";
                    text <=> root.edit-password;
                }
                Button {
                    text: "Згенерувати";
                    clicked => { root.generate-password-requested(); }
                }
            }
        }

        if AppState.error-message != "": Rectangle {
            border-radius: 6px;
            background: #3d1515;

            VerticalBox {
                padding: 10px;

                Text {
                    text: AppState.error-message;
                    color: #ff6b6b;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }

        HorizontalBox {
            spacing: 8px;

            Button {
                text: "Зберегти";
                primary: true;
                enabled: root.edit-title != "";
                clicked => {
                    AppState.save-entry({
                        id: AppState.selected-entry.id,
                        title: root.edit-title,
                        username: root.edit-username,
                        url: root.edit-url,
                        password: root.edit-password,
                        notes: root.edit-notes,
                        category: AppState.selected-entry.category,
                        favorite: AppState.selected-entry.favorite,
                        updated-at: AppState.selected-entry.updated-at,
                    });
                    AppState.reset-idle-timer();
                }
            }
            Button {
                text: "Скасувати";
                clicked => {
                    AppState.detail-mode = "view";
                    AppState.reset-idle-timer();
                }
            }
        }
    }
}
