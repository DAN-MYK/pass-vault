import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

// Універсальний діалог підтвердження небезпечних дій.
// Використовується для: видалення запису, виходу без збереження, тощо.
export component ConfirmDialog inherits Rectangle {
    in property <string> title: "Підтвердити дію";
    in property <string> message: "Ви впевнені?";
    in property <string> confirm-text: "Підтвердити";
    // true = червона кнопка (небезпечна дія)
    in property <bool> is-destructive: true;

    callback confirmed();
    callback cancelled();

    // Затемнення фону
    background: #00000099;

    // Клік на фон = скасування
    TouchArea {
        width: 100%; height: 100%;
        clicked => { root.cancelled(); }
    }

    // Картка
    Rectangle {
        width: 360px;
        height: self.preferred-height;
        border-radius: 12px;
        background: #16213e;
        drop-shadow-blur: 32px;
        drop-shadow-color: #000000aa;

        VerticalBox {
            padding: 32px;
            spacing: 20px;

            // Іконка + заголовок
            VerticalBox {
                spacing: 10px;
                alignment: center;

                Text {
                    text: root.is-destructive ? "⚠️" : "❓";
                    font-size: 36px;
                    horizontal-alignment: center;
                }

                Text {
                    text: root.title;
                    font-size: 18px;
                    font-weight: 700;
                    color: #e0e0e0;
                    horizontal-alignment: center;
                }
            }

            // Повідомлення
            Text {
                text: root.message;
                font-size: 14px;
                color: #8899bb;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            // Кнопки
            HorizontalBox {
                spacing: 12px;

                Button {
                    text: "Скасувати";
                    horizontal-stretch: 1;
                    clicked => { root.cancelled(); }
                }

                // Кнопка підтвердження — червона якщо деструктивна
                Rectangle {
                    horizontal-stretch: 1;
                    height: confirm-btn.height;
                    border-radius: 4px;
                    background: root.is-destructive
                        ? (confirm-btn-touch.has-hover ? #c0392b : #e74c3c)
                        : transparent;

                    animate background { duration: 100ms; }

                    confirm-btn-touch := TouchArea {
                        clicked => { root.confirmed(); }
                    }

                    confirm-btn := Button {
                        text: root.confirm-text;
                        primary: !root.is-destructive;
                        clicked => { root.confirmed(); }
                    }
                }
            }
        }
    }
}
