import { Button, LineEdit, VerticalBox } from "std-widgets.slint";
import { AppState } from "../globals.slint";

// Діалог входу/створення vault. Читає AppState напряму.
// Показується поверх AppWindow коли AppState.is-logged-in = false.
export component LoginDialog inherits Rectangle {
    background: #1a1a2e;

    VerticalLayout {
        alignment: center;
        padding: 0px;
        spacing: 0px;

        // Центрована картка
        Rectangle {
            width: 380px;
            height: self.preferred-height;
            border-radius: 12px;
            background: #16213e;
            drop-shadow-blur: 32px;
            drop-shadow-color: #00000066;

            VerticalBox {
                padding: 40px;
                spacing: 20px;
                alignment: start;

                // Заголовок
                Text {
                    text: AppState.is-new-vault ? "Створити сховище" : "Відкрити сховище";
                    font-size: 22px;
                    font-weight: 700;
                    color: #e0e0e0;
                    horizontal-alignment: center;
                }

                // Іконка замку
                Text {
                    text: "🔐";
                    font-size: 40px;
                    horizontal-alignment: center;
                }

                // Підказка
                Text {
                    text: AppState.is-new-vault
                        ? "Введіть мастер-пароль для нового сховища"
                        : "Введіть мастер-пароль";
                    font-size: 13px;
                    color: #8888aa;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                // Поле паролю
                password-input := LineEdit {
                    placeholder-text: "Мастер-пароль";
                    input-type: password;
                    enabled: !AppState.is-loading;
                    accepted(text) => { AppState.login(text); }
                }

                // Повідомлення про помилку
                if AppState.error-message != "": Rectangle {
                    border-radius: 6px;
                    background: #3d1515;

                    VerticalBox {
                        padding: 10px;

                        Text {
                            text: AppState.error-message;
                            color: #ff6b6b;
                            font-size: 12px;
                            wrap: word-wrap;
                            horizontal-alignment: center;
                        }
                    }
                }

                // Кнопка
                Button {
                    text: AppState.is-new-vault ? "Створити" : "Відкрити";
                    primary: true;
                    enabled: !AppState.is-loading && password-input.text != "";
                    clicked => { AppState.login(password-input.text); }
                }
            }
        }
    }
}
