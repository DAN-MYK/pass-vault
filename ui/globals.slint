export struct EntryItem {
    id: int,
    title: string,
    username: string,
    url: string,
    password: string,
    category: string,
    favorite: bool,
    updated-at: string,
}

export struct CategoryItem {
    id: int,
    name: string,
    icon: string,
    count: int,
}

export global AppState {
    in property <bool> is-locked;
    in property <string> error-message;
    in property <bool> is-loading;
}

